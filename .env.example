# AI Browser Controller — example environment file.
#
# Copy this file to `.env` and edit as needed. Every value below is OPTIONAL;
# the application ships with the same defaults baked into app/utils/config.py.
# All controller settings are prefixed with `ABC_`.

# ----- Browser -----
# Which browser engine Playwright launches: chromium | firefox | webkit
ABC_BROWSER=chromium
# Optional real-browser channel (e.g. chrome, msedge). Driving the user's
# installed Chrome instead of bundled Chromium is harder for bot-detection to
# flag. Leave blank to use Playwright's bundled engine.
# ABC_BROWSER_CHANNEL=chrome
# Run without a visible window (true) or with a visible window (false)
ABC_HEADLESS=true
# Viewport dimensions in pixels
ABC_VIEWPORT_WIDTH=1280
ABC_VIEWPORT_HEIGHT=800
# Default action/navigation timeout in milliseconds
ABC_TIMEOUT_MS=30000
# Optional custom User-Agent string (leave blank to use the browser default)
ABC_USER_AGENT=

# ----- Humanization (anti bot-detection) -----
# When true, typing is paced, the cursor travels a curved/wobbling path before
# clicking, and scrolling is lazy/incremental — so automation looks human.
ABC_HUMANIZE=true
# Approximate typing speed in words per minute (with natural jitter).
ABC_TYPING_WPM=25
# Stealth shrinks the automation FINGERPRINT (navigator.webdriver, the
# --enable-automation switch / "controlled by automated software" banner,
# missing window.chrome). Humanization covers behaviour; this covers the
# fingerprint hardened sites (e.g. Google sign-in) read. Best with a real
# browser channel (ABC_BROWSER_CHANNEL=chrome). Chromium-family only.
ABC_STEALTH=true

# ----- Event-driven waiting -----
# Hard ceiling (ms) for "wait quietly" operations like an online AI's streamed
# answer (wait_for_stable / wait_for_response). Default 5 minutes.
ABC_MAX_WAIT_MS=300000
# Generous ceiling (ms) for downloads, which can legitimately take far longer.
# Default 1 hour.
ABC_MAX_DOWNLOAD_WAIT_MS=3600000

# ----- No-image mode (MarkItDown) -----
# When true, pixel screenshots are suppressed and media is read as markdown via
# MarkItDown (the to_markdown tool). Toggle at runtime with set_no_image_mode.
ABC_NO_IMAGE_MODE=false

# ----- Recording -----
# Frames per second for screen recordings
ABC_RECORDING_FPS=24
# Path to the ffmpeg binary (SYSTEM dependency — must be installed separately)
ABC_FFMPEG=ffmpeg

# ----- API server -----
# Host/interface the FastAPI server binds to
ABC_HOST=127.0.0.1
# Port the FastAPI server listens on
ABC_PORT=8000

# ----- Storage (optional overrides) -----
# Absolute paths to override the default storage directories
# ABC_SCREENSHOT_DIR=
# ABC_RECORDING_DIR=
# Root holding one persistent user-data dir per named Chrome profile, plus the
# JSON pointer that remembers the active profile across chats/restarts.
# ABC_PROFILES_DIR=
# ABC_ACTIVE_PROFILE_FILE=
# Structured sessions, state snapshots, visual-diff masks, page memory, workflows.
# ABC_SESSION_DIR=
# ABC_SNAPSHOT_DIR=
# ABC_DIFF_DIR=
# ABC_MEMORY_DIR=
# ABC_WORKFLOW_DIR=

# ----- Website Skill System (persistent per-domain operational knowledge) -----
# Mode: OFF (disabled) | READ_ONLY (read but never modify) | LEARN (default).
ABC_DISCOVERY_MODE=LEARN
# Where per-domain skills live (default app/storage/website_skills).
# ABC_DISCOVERY_STORAGE=
# Confidence floor (0-100) below which a known route is auto-rediscovered.
ABC_DISCOVERY_CONFIDENCE_THRESHOLD=50
# Auto-discover/relearn on navigation, no user action (LEARN mode only).
ABC_DISCOVERY_AUTO_UPDATE=true
# Max pages a whole-site crawl (discover_website) will visit.
ABC_DISCOVERY_MAX_DEPTH=2

# ----- AI judgment (verify_goal / find_element / plan_actions) -----
# Uses the Claude SDK; falls back to a clear "unavailable" error without a key.
# ABC_AI_MODEL=claude-opus-4-8

# ----- Logging -----
# Log verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
ABC_LOG_LEVEL=INFO

# ----- AI provider credentials -----
# Required only when using the corresponding adapter / `start.py agent --provider`.
# Claude adapter (default model: claude-opus-4-8)
ANTHROPIC_API_KEY=
# OpenAI adapter (default model: gpt-4o)
OPENAI_API_KEY=
# Gemini adapter (default model: gemini-2.5-flash). GOOGLE_API_KEY is also accepted.
GEMINI_API_KEY=
# Optional: multiple keys to rotate past free-tier rate limits (comma/space-separated).
# On a 429 the adapter falls through to the next key. Folded together with GEMINI_API_KEY.
GEMINI_API_KEYS=
